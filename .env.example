# Optional default ProPresenter REST API base (Next.js server).
# Client-side Settings UI can override per browser via API request body.
PROPRESENTER_BASE_URL=http://127.0.0.1:50001

# Force mock client even when PROPRESENTER_BASE_URL is set (tests / demos).
# PROPRESENTER_USE_MOCK=true

# Optional bearer token if your ProPresenter deployment requires it.
# PROPRESENTER_TOKEN=
